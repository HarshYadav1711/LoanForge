# =============================================================================
# LoanForge API — copy to apps/server/.env and adjust for your machine
# =============================================================================

# MongoDB (local). Create the database on first connection.
MONGODB_URI=mongodb://127.0.0.1:27017/loanforge

# HTTP server
PORT=4000
NODE_ENV=development

# Auth — required. Use a long random string; never commit the real .env file.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — must match the Next.js dev server origin (no trailing slash)
CLIENT_URL=http://localhost:3000

# Local salary slip uploads (path is relative to apps/server when running npm scripts)
UPLOAD_DIR=uploads
