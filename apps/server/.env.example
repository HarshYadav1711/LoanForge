# MongoDB (local)
MONGODB_URI=mongodb://127.0.0.1:27017/loanforge

# HTTP server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — Next.js dev server
CLIENT_URL=http://localhost:3000

# Local file uploads (relative to apps/server)
UPLOAD_DIR=uploads
